    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "dompurify": "^3.4.5",
    "firebase": "^12.13.0",
    "lucide": "^1.16.0",
    "workbox-precaching": "^7.4.1"
  }
