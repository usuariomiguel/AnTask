{
  "name": "antask",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gestión de tareas y notas — sin servidores, sin cuentas, sin rastro.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p jsconfig.json",
